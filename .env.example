# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_template?schema=public

# JWT — generate strong secrets for production, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Cache (matches docker-compose defaults)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=60

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=10
