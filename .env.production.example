# Copy to .env.production and fill in real values before deploying.
# Loaded via `env_file:` in docker-compose.production.yml.

# Postgres image init (must match the credentials in DATABASE_URL below)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=nestjs_template

# App
CORS_ORIGIN=https://your-production-domain.example

# Database — host is `db`, the compose service name (internal network only)
DATABASE_URL=postgresql://postgres:replace-with-a-strong-password@db:5432/nestjs_template?schema=public

# JWT — generate strong secrets, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

# Cache — host is `redis`, the compose service name (internal network only)
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=60
